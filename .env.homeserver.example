# Homeserver deployment behind Nginx Proxy Manager or another reverse proxy.
# Keep NEXT_PUBLIC_API_GATEWAY_URL empty when the app is served through the same
# public domain and the frontend can use window.location.origin.

NEXT_PUBLIC_API_GATEWAY_URL=
NEXT_PUBLIC_SOCKET_PATH=/socket.io
NEXT_PUBLIC_DEFAULT_SESSION_ID=1
CORS_ALLOWED_ORIGINS=https://demo.example.com
TRUST_PROXY=true

MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_DATABASE=research_sessions
MYSQL_USER=research_user
MYSQL_PASSWORD=replace-with-a-strong-mysql-password
LEGACY_SIMULATED_DELAY_MS=1200

POSTGRES_DB=realtime_insights
POSTGRES_USER=insights_user
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
VIDEO_TOKEN_SECRET=replace-with-a-long-random-secret
DEFAULT_SESSION_ID=1
