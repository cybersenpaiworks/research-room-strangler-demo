# -----------------------------------------------------------------------------
# Public browser-facing configuration
# Leave NEXT_PUBLIC_API_GATEWAY_URL empty when the dashboard is served through
# the same nginx gateway. Set it explicitly only when you need a fixed public
# origin in the built frontend.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_GATEWAY_URL=
NEXT_PUBLIC_SOCKET_PATH=/socket.io
NEXT_PUBLIC_DEFAULT_SESSION_ID=1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://strangler.example.com
TRUST_PROXY=true

# -----------------------------------------------------------------------------
# Internal gateway port exposed by docker-compose. In a homeserver setup, place
# this behind your outer HTTPS reverse proxy.
# -----------------------------------------------------------------------------
GATEWAY_PORT=8080

# -----------------------------------------------------------------------------
# Legacy MySQL
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=super-secret-root-password
MYSQL_DATABASE=research_sessions
MYSQL_USER=research_user
MYSQL_PASSWORD=research_password
# Keep this high enough to make synchronous polling visibly painful during demos.
LEGACY_SIMULATED_DELAY_MS=1200

# -----------------------------------------------------------------------------
# Modern PostgreSQL + Redis
# -----------------------------------------------------------------------------
POSTGRES_DB=realtime_insights
POSTGRES_USER=insights_user
POSTGRES_PASSWORD=insights_password
VIDEO_TOKEN_SECRET=replace-with-a-long-random-secret
DEFAULT_SESSION_ID=1

# -----------------------------------------------------------------------------
# Optional for non-default topologies:
# LEGACY_SYNC_URL=http://legacy-yii:8080
# -----------------------------------------------------------------------------
